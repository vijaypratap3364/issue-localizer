# GitHub personal access token with public_repo (read) access.
# Required: the dataset miner uses the GitHub GraphQL API, which requires
# authentication even for public repos.
# Create one at https://github.com/settings/tokens (classic token with the
# "repo" scope, or a fine-grained token with read-only access to public repos).
GITHUB_TOKEN=

# Gemini API key used by the issue-localizing agent (src/agent.py) for its
# reasoning step. Free tier is fine -- the agent uses the Flash model.
# Create one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
